# Audit Energy — Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/audit_energy?schema=public"

# Ollama (IA Local)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# Resend (Email)
RESEND_API_KEY=""

# Upload
UPLOAD_DIR="./uploads"
OUTPUT_DIR="./output"
MAX_FILE_SIZE_MB=10
